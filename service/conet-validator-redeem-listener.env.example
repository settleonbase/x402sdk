# Copy to /etc/default/conet-validator-redeem-listener on the validator host (38.102.85.33).
# Secret files must be created ON THIS HOST ONLY — see beamio-no-master-json-remote-copy.mdc
# Redeem admin key (key_38.102.85.33 → 0xE974…6d1E): signs fundAndDepositValidators; 32 CNET/validator from contract balance.
CONET_VALIDATOR_REDEEM_LISTENER=1
CONET_VALIDATOR_NODE_IP=38.102.85.33
CONET_VALIDATOR_NEWCONET_DIR=/home/peter/ethereum-pos-mainnet
CONET_VALIDATOR_REDEEM_ADMIN_PRIVATE_KEY_FILE=/home/peter/ethereum-pos-mainnet/secrets/deposit_sender_private_key.txt
CONET_VALIDATOR_DEPOSIT_PRIVATE_KEY_FILE=/home/peter/ethereum-pos-mainnet/secrets/deposit_sender_private_key.txt
CONET_VALIDATOR_DEPOSIT_RPC_URL=https://publicrpc.conet.network
CONET_RPC_URL=https://publicrpc.conet.network
# HTTP RPC timeout for listener event polling (default 60000 ms; ethers default ~5s caused @TODO TIMEOUT logs)
# CONET_RPC_HTTP_TIMEOUT_MS=60000
# eth_getFilterChanges poll interval when using contract.on (default 12000 ms)
# CONET_LISTENER_POLLING_MS=12000
CONET_VALIDATOR_REDEEM_STATE_FILE=/home/peter/.conet-validator-redeem-state.json
# Live starts first; checkpoint = liveFromBlock-1, then backfill prior..checkpoint only (parallel, no overlap).
CONET_VALIDATOR_REDEEM_LISTENER_BLOCK_FILE=/home/peter/.conet-validator-redeem-listener-block.json
# Prysm validator keystore password — MUST match the password used when importing validator keys on this node.
# Prefer a secrets file on the validator host only (chmod 600, never commit):
CONET_VALIDATOR_KEYSTORE_PASSWORD_FILE=/home/peter/ethereum-pos-mainnet/secrets/validator_keystore_password.txt
# Prysm wallet password (often distinct from validator keystore password):
CONET_VALIDATOR_WALLET_PASSWORD_FILE=/home/peter/ethereum-pos-mainnet/secrets/prysm_wallet_password.txt
# Listener sets CONFIRM_REPLACE=REPLACE + DEPOSIT_NON_INTERACTIVE=YES automatically; set NO only to debug TTY deposit CLI.
# CONET_VALIDATOR_DEPOSIT_NON_INTERACTIVE=NO
# After on-chain deposit: auto-import append keystores into Prysm + reload validator only (default on).
# CONET_VALIDATOR_SKIP_IMPORT=YES
# CONET_VALIDATOR_RELOAD_VALIDATOR_AFTER_IMPORT=YES
# Full beacon+validator restart (05_restart) — default skip; import script reloads validator client only.
CONET_VALIDATOR_SKIP_BEACON_RESTART=YES
# Deprecated: use 08_import_append_validator_keys.sh (listener runs automatically after deposit).
# CONET_VALIDATOR_RUN_JOIN_SCRIPT=YES
# Or inline (less preferred; keep /etc/default chmod 640):
# KEYSTORE_PASSWORD=your-long-random-password
# WALLET_PASSWORD=your-prysm-wallet-password
# Hard getLogs floor (default 159057). Safety only — normal resume uses last checkpoint + 1.
# CONET_VALIDATOR_REDEEM_LISTENER_DEPLOY_BLOCK=159057
# One-time historical catchup when no checkpoint exists (omit on routine restarts):
# CONET_VALIDATOR_REDEEM_LISTENER_FROM_BLOCK=159057
# eth_getLogs chunk size (default 2000)
# CONET_VALIDATOR_REDEEM_LISTENER_LOG_CHUNK=2000
# Incremental getLogs backfill every 1–5 min (default 180000 ms = 3 min); safety net when eth filter expires.
# CONET_VALIDATOR_REDEEM_LISTENER_BACKFILL_TICK_MS=180000
# Log ALERT when checkpoint lags chain head by more than N blocks (default 500); cooldown 10 min between alerts.
# CONET_VALIDATOR_REDEEM_LISTENER_LAG_ALERT_BLOCKS=500
# CONET_VALIDATOR_REDEEM_LISTENER_LAG_ALERT_COOLDOWN_MS=600000
# Rebuild contract.on eth_newFilter subscription after each incremental backfill tick (default YES).
# CONET_VALIDATOR_REDEEM_LISTENER_REBUILD_LIVE_EACH_TICK=YES
# Claim / fundAndDeposit / Prysm import run through a single FIFO serial queue (shared redeem-admin nonce).
# See beamio-onchain-tx-serial-queue.mdc and src/x402sdk/src/onchainTxSerialQueue.ts.

# ---- CNET reward reporter (ValidatorNodeRewardIndexer.reportNodeReward) ----
# Default ON when CONET_VALIDATOR_REDEEM_LISTENER=1; set 0 to disable.
# CONET_VALIDATOR_HOURLY_REWARD_REPORT=1
# Prysm beacon REST (consensus balance delta per validator pubkey).
# CONET_VALIDATOR_BEACON_REST_URL=http://127.0.0.1:4100
# Poll interval for balance delta detection (default 60s).
# CONET_VALIDATOR_HOURLY_REWARD_TICK_MS=60000
# State file (last balance snapshots per validator pubkey).
# CONET_VALIDATOR_HOURLY_REWARD_STATE_FILE=/home/peter/.conet-validator-reward-reporter-state.json
# Max rows per on-chain report tx (default 40).
# CONET_VALIDATOR_HOURLY_REWARD_CHUNK=40
# CONET_VALIDATOR_HOURLY_REWARD_DRY_RUN=1

# ---- CL skim payout (settleNodeRewards → current beneficiary EOA) ----
# Default ON when CONET_VALIDATOR_REDEEM_LISTENER=1; set 0 to disable.
# CONET_VALIDATOR_CL_REWARD_PAYOUT=1
# Floor block for withdrawal scan (default: chainAddresses CONET_VALIDATOR_DEPOSIT_REDEEM_DEPLOY_BLOCK = proxy deploy block).
# CONET_VALIDATOR_CL_REWARD_PAYOUT_DEPLOY_BLOCK=181083
# CONET_VALIDATOR_DEPOSIT_REDEEM_DEPLOY_BLOCK=181083
# Prysm beacon REST for validator index → pubkey resolution.
# CONET_VALIDATOR_BEACON_REST_URL=http://127.0.0.1:4100
# Poll interval (default 60s).
# CONET_VALIDATOR_CL_REWARD_PAYOUT_TICK_MS=60000
# Blocks per eth_getBlock scan chunk (default 32).
# CONET_VALIDATOR_CL_REWARD_PAYOUT_CHUNK_BLOCKS=32
# Chunks processed per tick (default 1 = at most CHUNK_BLOCKS per tick; avoids one tick scanning to live head).
# CONET_VALIDATOR_CL_REWARD_PAYOUT_CHUNKS_PER_TICK=1
# State file (lastProcessedBlock + scanTargetBlock for restart-safe catch-up).
# CONET_VALIDATOR_CL_REWARD_PAYOUT_STATE_FILE=/home/peter/.conet-validator-cl-reward-payout-state.json
# CONET_VALIDATOR_CL_REWARD_PAYOUT_DRY_RUN=1
