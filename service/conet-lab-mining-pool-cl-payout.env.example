# Copy to /etc/default/conet-lab-mining-pool-cl-payout on the daemon host (e.g. 74.208.224.45).
# Secrets must be created ON THIS HOST ONLY — see beamio-no-master-json-remote-copy.mdc

CONET_LAB_MINING_POOL_CL_PAYOUT=1
CONET_LAB_MINING_POOL_PUBKEYS_FILE=/home/peter/x402sdk/deployments/conet-lab-mining-pool-pubkeys.json
CONET_LAB_MINING_POOL_ADDRESS=0x32bE583C8e778FFfC5107BF34820c2B225336201
CONET_VALIDATOR_DEPOSIT_RPC_URL=https://publicrpc.conet.network
CONET_RPC_URL=https://publicrpc.conet.network
CONET_VALIDATOR_BEACON_REST_URL=http://127.0.0.1:4100

# Redeem proxy admin — signs withdrawNative(miningPool, amount). Must match on-chain admins().
CONET_LAB_MINING_POOL_CL_PAYOUT_ADMIN_PRIVATE_KEY_FILE=/home/peter/secrets/redeem_contract_admin.txt

CONET_LAB_MINING_POOL_CL_PAYOUT_TICK_MS=60000
CONET_LAB_MINING_POOL_CL_PAYOUT_CHUNK_BLOCKS=32
CONET_LAB_MINING_POOL_CL_PAYOUT_CHUNKS_PER_TICK=1
# Fast backfill (optional on VA host): 128×2 blocks every 15s; persist cursor after each chunk
# CONET_LAB_MINING_POOL_CL_PAYOUT_TICK_MS=15000
# CONET_LAB_MINING_POOL_CL_PAYOUT_CHUNK_BLOCKS=128
# CONET_LAB_MINING_POOL_CL_PAYOUT_CHUNKS_PER_TICK=2
CONET_LAB_MINING_POOL_CL_PAYOUT_STATE_FILE=/home/peter/.conet-lab-mining-pool-cl-payout-state.json

# Parallel listen + backfill every tick / every process start:
#   listening — always scans current liveHead (tip); does not wait for backfill
#   backfill   — [lastListeningEndBlock+1 | deploy block .. liveHead-1]
# When backfill reaches liveHead-1 and liveHead was listened, lastListeningEndBlock is persisted.
CONET_LAB_MINING_POOL_DEPLOY_BLOCK=326705

# CONET_LAB_MINING_POOL_CL_PAYOUT_DRY_RUN=1
# Per-withdrawal skim ceiling: CL rewards are ≪ 1 CNET; ≥ this amount is never skimmed (exit/partial principal).
# Default 1 CNET = 1000000000000000000 wei. Lower = stricter (safer); do not raise unless you know rewards can exceed it.
# CONET_LAB_MINING_POOL_CL_FULL_EXIT_FLOOR_WEI=1000000000000000000
